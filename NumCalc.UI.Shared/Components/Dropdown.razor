@typeparam TItem

<div class="dropdown__container @(_isOpen ? "open" : "")" @onmousedown:stopPropagation>
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="dropdown__label">@Label</label>
    }

    <div class="dropdown__trigger-button trigger-button" @onclick="ToggleDropdown">
        <span class="selected-text">@GetSelectedText()</span>
        <span class="chevron">▼</span>
    </div>

    @if (_isOpen)
    {
        <div class="dropdown__backdrop" @onclick="Close"></div>
        
        <ul class="dropdown__menu hoverable">
            @if (MultiSelect)
            {
                <li class="dropdown__menu-item dropdown-item @(IsAllSelected ? "selected" : "")">
                    <label for="@($"{_dropdownId}_all")">
                        <input type="checkbox"
                               class="dropdown-item__checkbox"
                               id="@($"{_dropdownId}_all")"
                               checked="@IsAllSelected"
                               @onchange="OnSelectAllChanged" />
                        <span class="dropdown-item__checkmark"></span>
                        <span class="dropdown-item__text">Select All</span>
                    </label>
                </li>
            }

            @foreach (var (item, index) in Data.Select((item, i) => (item, i)))
            {
                var isSelected = IsSelected(item);
                var checkboxId = $"{_dropdownId}_item_{index}";
                <li class="dropdown__menu-item dropdown-item @(isSelected ? "selected" : "")">
                    <label for="@checkboxId">
                        <input type="checkbox"
                               class="dropdown-item__checkbox"
                               id="@checkboxId"
                               checked="@isSelected"
                               @onchange="() => OnItemClick(item)" />
                        @if (MultiSelect)
                        {
                            <span class="dropdown-item__checkmark"></span>                        
                        }
                        <span class="dropdown-item__text">@TextField(item)</span>
                    </label>
                </li>
            }
        </ul>
    }
</div>

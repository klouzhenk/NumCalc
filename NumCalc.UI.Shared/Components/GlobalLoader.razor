@if (_isVisible)
{
    <div class="loader-overlay">
        <div class="spinner"></div>
    </div>
}

<style>
    .loader-overlay {
        position: fixed; /* Фіксуємо відносно вікна */
        top: 0; 
        left: 0; 
        width: 100vw; 
        height: 100vh;
        background-color: rgba(0, 0, 0, 0.5); /* Напівпрозорий чорний фон */
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999; /* Поверх усього, навіть модалок */
        backdrop-filter: blur(3px); /* Ефект розмиття фону (опціонально) */
    }

    .spinner {
        width: 50px;
        height: 50px;
        border: 5px solid #f3f3f3;
        border-top: 5px solid #3498db; /* Основний колір */
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
</style>
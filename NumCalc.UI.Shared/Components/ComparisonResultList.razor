@typeparam TItem

<ul class="root-finding-result__list">
    @foreach (var item in Items ?? [])
    {
        <li class="root-finding-result__item comparison-result__item @(IsBest(item) ? "marked" : "")">
            @ItemTemplate(item)
        </li>
    }
</ul>

@code {
    [Parameter] public IEnumerable<TItem>? Items { get; set; }
    [Parameter] public Func<TItem, bool> IsBest { get; set; } = _ => false;
    [Parameter, EditorRequired] public RenderFragment<TItem> ItemTemplate { get; set; } = null!;
}

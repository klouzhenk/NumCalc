<div class="save-input-actions">
    @if (ShowSaveForm)
    {
        <div class="save-input-form">
            <input type="text" class="input-group__input"
                   value="@SaveName"
                   @oninput="@(e => SaveNameChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty))"
                   placeholder="@Localizer["SaveInputName"]" />
            <button class="button button--secondary" @onclick="OnConfirmSave">@Localizer["Save"]</button>
            <button class="button button--ghost" @onclick="OnHideSave">@Localizer["Cancel"]</button>
        </div>
    }
    else
    {
        <button class="button button--ghost" @onclick="OnShowSave">@Localizer["SaveInputs"]</button>
    }
    <button class="button button--ghost" @onclick="OnLoad">@Localizer["LoadInputs"]</button>
</div>

@if (Size > 1)
{
    <div class="matrix-input__wrapper">
        <div class="matrix-input">
            @for (var equationIndex = 0; equationIndex < Size; equationIndex++)
            {
                <div class="matrix-input__row">
                    <div class="matrix-input__row-label">@(equationIndex + 1)</div>
                
                    <div class="matrix-input__row-content">
                        @for (var variableIndex = 0; variableIndex < Size; variableIndex++)
                        {
                            var eqIdx = equationIndex;
                            var varIdx = variableIndex;
                            <div class="matrix-input__cell">
                                <input type="number" step="any"
                                       value="@Coefficients[eqIdx, varIdx]"
                                       @onchange="e => { if (double.TryParse(e.Value?.ToString(), out var v)) Coefficients[eqIdx, varIdx] = v; }" />

                                <span>x<sub>@(varIdx + 1)</sub></span>
                            </div>

                            @if (varIdx != Size - 1)
                            {
                                <div class="matrix-input__operator">+</div>
                            }
                        }

                        <div class="matrix-input__operator">=</div>

                        @{ var rhsIdx = equationIndex; }
                        <input type="number" step="any"
                               value="@Rhs[rhsIdx]"
                               @onchange="e => { if (double.TryParse(e.Value?.ToString(), out var v)) Rhs[rhsIdx] = v; }" />
                    </div>
                </div>
            }
        </div>
    </div>
}
<div class="math-input">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="input-group__label math-input__label">@Label</label>
    }

    <div class="math-input__wrapper">
        <math-field @ref="_mathFieldRef" class="math-input__field"></math-field>
        
        <button type="button" class="button math-input__copy-btn" @onclick="CopyToClipboard" title="@Localizer["CopyLaTeX"]">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
        </button>
    </div>
</div>

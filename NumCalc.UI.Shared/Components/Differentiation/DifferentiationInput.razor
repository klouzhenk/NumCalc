@using NumCalc.Shared.Enums.Differentiation
@using NumCalc.UI.Shared.Components
@using NumCalc.UI.Shared.Enums.Differentiation

@if (Method is DifferentiationMethod.FiniteDifferences)
{
    <div class="input-section__wrapper">
        <Tooltip>
            <Content>
                <MathInput Label="f(x)" @ref="_mathInput" />
            </Content>
            <Hint>Function f(x) to differentiate. Use standard math notation, e.g. sin(x), x^2 + 3*x.</Hint>
        </Tooltip>
    </div>

    <div class="input-section__wrapper">
        <Tooltip>
            <Content>
                <div class="input-group">
                    <label class="input-group__label">x*</label>
                    <input type="number" step="any" class="input-group__input" @bind="_queryPoint" />
                </div>
            </Content>
            <Hint>Query point x* — evaluate the derivative at this value.</Hint>
        </Tooltip>
        
        <Tooltip>
            <Content>
                <Dropdown TItem="int"
                          Label="Derivative order"
                          Data="@(new[] { 1, 2 })"
                          @bind-Value="_derivativeOrder"
                          TextField="@(n => n == 1 ? "1st" : "2nd")" />
            </Content>
            <Hint>Order of the derivative: 1 for f'(x), 2 for f''(x).</Hint>
        </Tooltip>
        
        <Tooltip>
            <Content>
                <div class="input-group">
                    <label class="input-group__label">Step size (h)</label>
                    <input type="number" step="any" class="input-group__input" @bind="_stepSize" />
                </div>
            </Content>
            <Hint>Step size h in finite-difference formulas. Default 0.001 balances truncation and round-off error.</Hint>
        </Tooltip>
    </div>
}
else
{
    @if (Mode is DifferentiationInputMode.Function)
    {
        <div class="input-section__wrapper">
            <Tooltip>
                <Content>
                    <MathInput Label="f(x)" @ref="_mathInput" />
                </Content>
                <Hint>Function f(x) to differentiate symbolically via Lagrange polynomial interpolation.</Hint>
            </Tooltip>
            <Tooltip>
                <Content>
                    <div class="input-group">
                        <label class="input-group__label">x*</label>
                        <input type="number" step="any" class="input-group__input" @bind="_queryPoint" />
                    </div>
                </Content>
                <Hint>Query point x* — evaluate the derivative at this value.</Hint>
            </Tooltip>
        </div>
    }

    <NodeTable ShowY="@(Mode is DifferentiationInputMode.RawData)" @ref="_nodeTable" />

    @if (Mode is DifferentiationInputMode.RawData)
    {
        <Tooltip>
            <Content>
                <div class="input-group">
                    <label class="input-group__label">x*</label>
                    <input type="number" step="any" class="input-group__input" @bind="_queryPoint" />
                </div>
            </Content>
            <Hint>Query point x* — evaluate the derivative at this value.</Hint>
        </Tooltip>
    }
}

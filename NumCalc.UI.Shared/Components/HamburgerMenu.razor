@using NumCalc.UI.Shared.Enums
@using NumCalc.UI.Shared.Utils

<button class="hamburger @(_isMenuOpen ? "hamburger--active" : "")" @onclick="ToggleMenu">
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
</button>

<div class="hamburger-menu__overlay @(_isMenuOpen ? "visible" : "")" @onclick="CloseMenu"></div>

<aside class="hamburger-menu @(_isMenuOpen ? "open" : "")">
    <ul class="hamburger-menu__list hoverable">
        @if (AuthStateService.IsAuthenticated)
        {
            <li @onclick="@(() => NavigationManager.NavigateTo("/dashboard"))">
                @Localizer[nameof(NavigationItem.Dashboard)]
            </li>
        }
        @foreach (var item in NavigationUtils.NavigationItems)
        {
            <li @onclick="() => OnListItemClick(item.Key)">
                @Localizer[item.Key.ToString()]
            </li>
        }
    </ul>
</aside>
@using NumCalc.UI.Shared.Components
@using NumCalc.UI.Shared.Enums.ODE

<div class="input-section__wrapper input-section__wrapper--ode-function">
    <Tooltip>
        <Content>
            <MathInput Label="f(x, y) — right-hand side of y' = f(x, y)" @ref="_mathInput" />
        </Content>
        <Hint>
            e.g. x + y, -2*x*y, x^2 - y
        </Hint>
    </Tooltip>
    
    <div class="input-group">
        <label class="input-group__label">x₀</label>
        <input type="number" step="any" class="input-group__input" @bind="_initialX"/>
    </div>
    <div class="input-group">
        <label class="input-group__label">y₀</label>
        <input type="number" step="any" class="input-group__input" @bind="_initialY"/>
    </div>
</div>

<div class="input-section__wrapper">
    <div class="input-group">
        <label class="input-group__label">x target</label>
        <input type="number" step="any" class="input-group__input" @bind="_targetX" />
    </div>
    @if (Method is OdeMethod.Picard)
    {
        <Dropdown TItem="int"
                  Label="Approximation order (k)"
                  Data="@(Enumerable.Range(1, 10))"
                  TextField="@(i => i.ToString())"
                  @bind-Value="_picardOrder" />
    }
    <div class="input-group">
        <label class="input-group__label">Step size (h)</label>
        <input type="number" step="any" min="0.0001" class="input-group__input" @bind="_stepSize" />
    </div>
</div>
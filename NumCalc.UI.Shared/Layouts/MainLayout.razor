@using NumCalc.UI.Shared.Components
@inherits LayoutComponentBase
@inject NavigationManager NavManager

<div class="layout-container">
    <header class="top-bar">
        <div class="brand">
            <span class="brand-icon">∫</span> NumCalc
        </div>
        
        <button class="hamburger @(_isMenuOpen ? "active" : "")" @onclick="ToggleMenu">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        </button>
    </header>

    <main class="content-area">
        @Body
    </main>

    <div class="sidebar-overlay @(_isMenuOpen ? "visible" : "")" @onclick="CloseMenu"></div>

    <aside class="right-sidebar @(_isMenuOpen ? "open" : "")">
        <div class="sidebar-header">
            <h3>Menu</h3>
        </div>
        <div class="sidebar-content">
            <Navigation OnLinkClick="CloseMenu" />
        </div>
    </aside>
    
    <GlobalLoader />
    <ToastContainer />
</div>

@code {
    private bool _isMenuOpen;

    private void ToggleMenu() => _isMenuOpen = !_isMenuOpen;
    private void CloseMenu() => _isMenuOpen = false;

    protected override void OnInitialized()
    {
        NavManager.LocationChanged += (_, _) => CloseMenu();
    }
}

<style>
    .layout-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        overflow: hidden;
    }

    .top-bar {
        height: 60px;
        background: #fff;
        border-bottom: 1px solid #eee;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 50;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    .brand {
        font-size: 1.25rem;
        font-weight: bold;
        color: #2c3e50;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .brand-icon {
        color: #3498db;
        font-size: 1.5rem;
    }

    .content-area {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        background-color: #f8f9fa;
        position: relative;
    }

    /* --- HAMBURGER BUTTON --- */
    .hamburger {
        background: none;
        border: none;
        cursor: pointer;
        width: 30px;
        height: 20px;
        position: relative;
        z-index: 200; /* Вище ніж меню, щоб завжди можна було натиснути */
    }

    .bar {
        display: block;
        width: 100%;
        height: 3px;
        background-color: #333;
        position: absolute;
        transition: all 0.3s ease-in-out;
        border-radius: 2px;
    }

    .bar:nth-child(1) { top: 0; }
    .bar:nth-child(2) { top: 8px; }
    .bar:nth-child(3) { top: 16px; }

    /* Анімація перетворення в хрестик */
    .hamburger.active .bar:nth-child(1) { transform: rotate(45deg); top: 8px; }
    .hamburger.active .bar:nth-child(2) { opacity: 0; }
    .hamburger.active .bar:nth-child(3) { transform: rotate(-45deg); top: 8px; }


    /* --- SIDEBAR (OVERLAY) --- */
    .right-sidebar {
        position: fixed;
        top: 0;
        right: 0;
        width: 280px;
        height: 100vh;
        background-color: #2c3e50;
        box-shadow: -5px 0 15px rgba(0,0,0,0.1);
        z-index: 100; /* Поверх контенту */
        transform: translateX(100%); /* За замовчуванням сховане праворуч */
        transition: transform 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
        display: flex;
        flex-direction: column;
    }

    .right-sidebar.open {
        transform: translateX(0); /* Виїжджає */
    }

    .sidebar-header {
        height: 60px;
        display: flex;
        align-items: center;
        padding-left: 20px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        color: white;
    }

    .sidebar-content {
        flex: 1;
        overflow-y: auto;
    }

    /* --- BACKDROP (Затемнення) --- */
    .sidebar-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: rgba(0,0,0,0.4);
        z-index: 90; /* Нижче меню, але вище контенту */
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease;
        backdrop-filter: blur(2px); /* Розмиття фону */
    }

    .sidebar-overlay.visible {
        opacity: 1;
        visibility: visible;
    }
</style>
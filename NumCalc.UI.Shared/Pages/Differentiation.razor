@page "/differentiation"
@using NumCalc.Shared.Enums.Differentiation
@using NumCalc.UI.Shared.Components
@using NumCalc.UI.Shared.Components.Differentiation
@using NumCalc.UI.Shared.Enums.Differentiation

@inherits BasePage<Differentiation>

<div class="page-wrapper page__differentiation">
    <div class="differentiation__form-wrapper">
        <div class="page__filters-container">
            <Dropdown TItem="DifferentiationMethod"
                      Label="Method"
                      Data="@(Enum.GetValues<DifferentiationMethod>())"
                      @bind-Value="_method"
                      @bind-Value:after="ResetResult"
                      TextField="@(item => item.ToString())"/>

            @if (_method is DifferentiationMethod.FiniteDifferences)
            {
                <Dropdown TItem="FiniteDiffVariant"
                          Label="Variant"
                          Data="@(Enum.GetValues<FiniteDiffVariant>())"
                          @bind-Value="_variant"
                          @bind-Value:after="ResetResult"
                          TextField="@(item => item.ToString())"/>
            }
            else
            {
                <Switch TItem="DifferentiationInputMode"
                        Label="@Localizer["Mode"]"
                        Data="@(Enum.GetValues<DifferentiationInputMode>())"
                        @bind-Value="_mode"
                        @bind-Value:after="ResetResult"
                        TextField="@(item => item.ToString())"/>
            }
        </div>

        <div class="differentiation__form">
            <DifferentiationInput Method="_method" Mode="_mode" @ref="_input" />
            <div class="form-actions">
                <button class="button button--primary" @onclick="Calculate">Calculate</button>
                @if (Result is not null)
                {
                    <button class="button button--secondary" @onclick="ExportPdfAsync">@Localizer["ExportPdf"]</button>
                }
            </div>
        </div>
    </div>
    
    <section>
        <div class="chart__container">
            <div class="chart" id="@ChartContainerId" style="display: @(IsChartVisible ? "block" : "none");"></div>
            <span class="remark" style="display: @(IsChartVisible ? "none" : "block");">Click Calculate to view result</span>
        </div>
        
        @if (Result is not null)
        {
            <div class="differentiation-result">
                <div class="differentiation-result__answer">
                    @if (_method is DifferentiationMethod.FiniteDifferences)
                    {
                        <span>@SelectedStep?.Value</span>
                    }
                    else
                    {
                        <span>f'(x*) = @Result.DerivativeValue.ToString("G6")</span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Result.PolynomialLatex))
                {
                    <div class="differentiation-result__polynomial">
                        <span class="solution-steps__item-formula">@Result.PolynomialLatex</span>
                    </div>
                }

                <SolutionStepsList Steps="@FilteredSteps"/>
            </div>
        }
        else
        {
            <div class="root-finding-result__container--empty">
                <span class="remark">Click Calculate to view result</span>
            </div>
        }
    </section>
</div>

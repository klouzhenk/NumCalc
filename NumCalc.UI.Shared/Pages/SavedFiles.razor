@page "/saved-files"
@inherits BasePage<SavedFiles>

<div class="page-wrapper page__saved-files">
    <h2>@Localizer["SavedFiles"]</h2>

    @if (Files is null)
    {
        <p>@Localizer["Loading"]</p>
    }
    else if (Files.Count == 0)
    {
        <p>@Localizer["NoRecords"]</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>@Localizer["FileName"]</th>
                    <th>@Localizer["Type"]</th>
                    <th>@Localizer["Method"]</th>
                    <th>@Localizer["Date"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var file in Files)
                {
                    <tr>
                        <td>@file.FileName</td>
                        <td>@file.Type</td>
                        <td>@file.MethodName</td>
                        <td>@file.CreatedAt.ToLocalTime().ToString("g")</td>
                        <td class="data-table__actions">
                            <button class="button button--secondary" @onclick="() => DownloadAsync(file.Id, file.FileName)">
                                @Localizer["Download"]
                            </button>
                            <button class="button button--danger" @onclick="() => DeleteAsync(file.Id)">
                                @Localizer["Delete"]
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

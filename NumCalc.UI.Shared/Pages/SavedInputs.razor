@page "/saved-inputs"
@using NumCalc.UI.Shared.Components
@inherits BasePage<SavedInputs>

<div class="page-wrapper page__saved-inputs">
    <h2>@Localizer["SavedInputs"]</h2>

    @if (SavedInputsData is null)
    {
        <div class="center-container"><span>@Localizer["Loading"]</span></div>
    }
    else if (SavedInputsData.Count == 0)
    {
        <div class="center-container"><span>@Localizer["NoRecords"]</span></div>
    }
    else
    {
        <div class="data-table__wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>@Localizer["Name"]</th>
                        <th>@Localizer["Type"]</th>
                        <th>@Localizer["Date"]</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var input in SavedInputsData)
                    {
                        <tr>
                            <td>@input.Name</td>
                            <td>@input.Type</td>
                            <td>@input.CreatedAt.ToLocalTime().ToString("g")</td>
                            <td class="data-table__actions">
                                <button class="button button--icon" @onclick="() => DeleteAsync(input.Id)">
                                    <SvgIcon Name="trash" />
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

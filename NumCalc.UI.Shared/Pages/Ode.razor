@page "/ode"
@using NumCalc.UI.Shared.Components
@using NumCalc.UI.Shared.Components.ODE
@using NumCalc.Shared.DTOs.ODE
@using NumCalc.UI.Shared.Enums.Roots
@using OdeMethod = NumCalc.Shared.Enums.ODE.OdeMethod

@inherits BasePage<Ode>

<div class="page-wrapper page__ode">
    <div class="ode__form-wrapper">
        <div class="page__filters-container">
            <Switch TItem="AnalysisMode"
                    Data="@(Enum.GetValues<AnalysisMode>())"
                    @bind-Value="_mode"
                    @bind-Value:after="ResetResult"
                    TextField="@(item => item.ToString())"
                    Label="@Localizer["AnalysisMode"]" />

            @if (_mode is AnalysisMode.Single)
            {
                <Tooltip>
                    <Content>
                        <Dropdown TItem="OdeMethod"
                                  Label="Method"
                                  Data="@(Enum.GetValues<OdeMethod>())"
                                  @bind-Value="_method"
                                  @bind-Value:after="ResetResult"
                                  TextField="@(item => item.ToString())"/>
                    </Content>
                    <Hint>
                        Picard's method is symbolic and converges only near x₀. Keep |x_target − x₀| small (typically &lt; 1).
                        <br/><br/>
                        Higher approximation order on wide intervals will diverge or be very slow.
                    </Hint>
                </Tooltip>
            }
            else
            {
                <Dropdown TItem="OdeMethod"
                          Label="Methods"
                          Data="@(Enum.GetValues<OdeMethod>().Where(method => method is not OdeMethod.Picard))"
                          MultiSelect="true"
                          @bind-SelectedItems="_benchmarkMethods"
                          @bind-SelectedItems:after="ResetResult"
                          TextField="@(item => item.ToString())"/>
            }
        </div>

        <div class="ode__form">
            <OdeInput Method="_method" @ref="_input" />
            <div class="form-actions">
                <button class="button button--primary" @onclick="Calculate">Calculate</button>
                @if (_mode is AnalysisMode.Single && Result is not null)
                {
                    <button class="button button--secondary" @onclick="ExportPdfAsync">@Localizer["ExportPdf"]</button>
                }
            </div>
        </div>
    </div>

    <ResultPanel HasResult="Result is not null || ComparisonResult is not null">
        <Header>
            @if (_mode is AnalysisMode.Single && Result is not null)
            {
                <span>y(@(Result!.SolutionPoints?.LastOrDefault()?.X?.ToString("G6") ?? "?")) ≈ @Result.SolutionPoints?.LastOrDefault()?.Y?.ToString("G6")</span>
                <LatexDisplay Latex="@Result.PolynomialLatex" AdditionalCssClass="result-panel__formula" />
            }
            else
            {
                <span>@Localizer["Benchmark"]</span>
            }
        </Header>
        <ChartContent>
            <div class="chart__container">
                <div class="chart" id="@ChartContainerId" style="display: @(IsChartVisible ? "block" : "none");"></div>
                <span class="remark" style="display: @(IsChartVisible ? "none" : "block");">Click Calculate to view result</span>
            </div>
        </ChartContent>
        <ResultContent>
            @if (_mode is AnalysisMode.Single)
            {
                <SolutionStepsList Steps="Result?.SolutionSteps" />
            }
            else if (ComparisonResult?.Results is { Count: > 0 })
            {
                <ComparisonResultList TItem="OdeBenchmarkResultDto"
                                      Items="ComparisonResult.Results"
                                      IsBest="@(item => item.Method == ComparisonResult.BestMethod)">
                    <ItemTemplate Context="item">
                        <span class="root-finding-result__item-title">@Localizer[item.Method.ToString()]</span>
                        <div class="root-finding-result__item-text">
                            <span class="root-finding-result__item-subtitle">y(x*)</span>: @(item.FinalY?.ToString("G6") ?? "—") &nbsp;|&nbsp;
                            <span class="root-finding-result__item-subtitle">@Localizer["ExecutionTime"]</span>: @item.ExecutionTimeMs.ToString("F3") @Localizer["ms"]
                        </div>
                    </ItemTemplate>
                </ComparisonResultList>
            }
        </ResultContent>
    </ResultPanel>
</div>

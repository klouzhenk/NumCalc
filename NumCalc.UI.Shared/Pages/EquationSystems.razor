@page "/equation-systems"
@using NumCalc.Shared.DTOs.EquationSystems
@using NumCalc.Shared.Enums.EquationSystems
@using NumCalc.UI.Shared.Enums.EquationSystems
@using NumCalc.UI.Shared.Components
@using NumCalc.UI.Shared.Components.EquationSystems
@using NumCalc.UI.Shared.Models.User.Enums
@using NumCalc.UI.Shared.Enums.Roots

@inherits BasePage<EquationSystems>

<div class="page-wrapper page__equation-systems">
    <div class="equation-systems__form-wrapper">
        <div class="page__filters-container">
            <Switch TItem="EquationSystemCategory"
                    Label="@Localizer["Category"]"
                    Data="@(Enum.GetValues<EquationSystemCategory>())"
                    @bind-Value="Category"
                    @bind-Value:after="ResetResult"
                    TextField="@(item => item.ToString())"/>

            <Switch TItem="AnalysisMode"
                    Data="@(Enum.GetValues<AnalysisMode>())"
                    @bind-Value="_mode"
                    @bind-Value:after="ResetResult"
                    TextField="@(item => item.ToString())"
                    Label="@Localizer["AnalysisMode"]" />

            @if (_mode is AnalysisMode.Single)
            {
                @if (Category is EquationSystemCategory.Linear)
                {
                    <Dropdown TItem="LinearSystemMethod"
                              Label="Method"
                              Data="@(Enum.GetValues<LinearSystemMethod>())"
                              @bind-Value="LinearMethod"
                              @bind-Value:after="ResetResult"
                              TextField="@(item => item.ToString())"/>
                }
                else
                {
                    <Dropdown TItem="NonLinearSystemMethod"
                              Label="Method"
                              Data="@(Enum.GetValues<NonLinearSystemMethod>())"
                              @bind-Value="NonLinearMethod"
                              @bind-Value:after="ResetResult"
                              TextField="@(item => item.ToString())"/>
                }
            }
            else
            {
                @if (Category is EquationSystemCategory.Linear)
                {
                    <Dropdown TItem="LinearSystemMethod"
                              Label="Methods"
                              Data="@(Enum.GetValues<LinearSystemMethod>())"
                              MultiSelect="true"
                              @bind-SelectedItems="_linearBenchmarkMethods"
                              @bind-SelectedItems:after="ResetResult"
                              TextField="@(item => item.ToString())"/>
                }
                else
                {
                    <Dropdown TItem="NonLinearSystemMethod"
                              Label="Methods"
                              Data="@(Enum.GetValues<NonLinearSystemMethod>())"
                              MultiSelect="true"
                              @bind-SelectedItems="_nonLinearBenchmarkMethods"
                              @bind-SelectedItems:after="ResetResult"
                              TextField="@(item => item.ToString())"/>
                }
            }

            <Dropdown TItem="int"
                      Label="Size"
                      Data="@_sizes"
                      @bind-Value="Size"
                      @bind-Value:after="ResetResult"
                      TextField="@(item => $"{item}×{item}")"/>
        </div>

        <div class="equation-systems__form">
            @if (Category is EquationSystemCategory.Linear)
            {
                <LinearSystemInput Size="Size" @ref="_linearInput" />
            }
            else
            {
                <EquationList Size="Size" @ref="_equationList" />
            }

            <div class="form-actions">
                <button class="button button--primary" @onclick="Calculate">@Localizer["Calculate"]</button>
                @if (_mode is AnalysisMode.Single && Result is not null)
                {
                    <button class="button button--secondary" @onclick="ExportPdfAsync">@Localizer["ExportPdf"]</button>
                }
            </div>
        </div>
    </div>

    <ResultPanel HasResult="Result is not null || LinearComparisonResult is not null || NonLinearComparisonResult is not null">
        <Header>
            @if (_mode is AnalysisMode.Single && Result is not null)
            {
                <div class="equation-systems-result__roots">
                    @for (var i = 0; i < Result?.Roots?.Count; i++)
                    {
                        <span>x<sub>@(i + 1)</sub> = @Result.Roots[i].ToString("G6")</span>
                    }
                </div>
            }
            else
            {
                <span>@Localizer["Benchmark"]</span>
            }
        </Header>
        <ChartContent>
            <div class="chart__container">
                <div class="chart" id="@ChartContainerId" style="display: @(IsChartVisible ? "block" : "none");"></div>
                <span class="remark" style="display: @(IsChartVisible ? "none" : "block");">@Localizer["ClickCalculateToViewResult"]</span>
            </div>
        </ChartContent>
        <ResultContent>
            @if (_mode is AnalysisMode.Single)
            {
                <SolutionStepsList Steps="Result?.SolutionSteps" />
            }
            else if (Category is EquationSystemCategory.Linear && LinearComparisonResult?.Results is { Count: > 0 })
            {
                <ComparisonResultList TItem="LinearSystemBenchmarkResultDto"
                                      Items="LinearComparisonResult.Results"
                                      IsBest="@(item => item.Method == LinearComparisonResult.BestMethod)">
                    <ItemTemplate Context="item">
                        <span class="comparison-result__item-title">@Localizer[item.Method.ToString()]</span>
                        <div class="comparison-result__item-text">
                            @if (item.Roots is { Count: > 0 })
                            {
                                <span>@string.Join(", ", item.Roots.Select((r, i) => $"x{i + 1} = {r:G6}"))</span>
                                <span> &nbsp;|&nbsp; </span>
                            }
                            <span class="comparison-result__item-subtitle">@Localizer["ExecutionTime"]</span>: @item.ExecutionTimeMs.ToString("F3") @Localizer["ms"]
                        </div>
                    </ItemTemplate>
                </ComparisonResultList>
            }
            else if (Category is EquationSystemCategory.NonLinear && NonLinearComparisonResult?.Results is { Count: > 0 })
            {
                <ComparisonResultList TItem="NonLinearSystemBenchmarkResultDto"
                                      Items="NonLinearComparisonResult.Results"
                                      IsBest="@(item => item.Method == NonLinearComparisonResult.BestMethod)">
                    <ItemTemplate Context="item">
                        <span class="comparison-result__item-title">@Localizer[item.Method.ToString()]</span>
                        <div class="comparison-result__item-text">
                            @if (item.Roots is { Count: > 0 })
                            {
                                <span>@string.Join(", ", item.Roots.Select((r, i) => $"x{i + 1} = {r:G6}"))</span>
                                <span> &nbsp;|&nbsp; </span>
                            }
                            <span class="comparison-result__item-subtitle">@Localizer["ExecutionTime"]</span>: @item.ExecutionTimeMs.ToString("F3") @Localizer["ms"]
                        </div>
                    </ItemTemplate>
                </ComparisonResultList>
            }
        </ResultContent>
    </ResultPanel>
</div>

<SavedInputDataPanel Type="CalculationType.EquationSystems"
                     OnSave="SaveInputAsync"
                     OnLoad="LoadFromJsonAsync" />
@using NumCalc.UI.Shared.Enums.Roots
@using NumCalc.UI.Shared.Components

@inherits BasePage

@page "/root-finding"

<div class="page-wrapper page__root-finding">
    <div class="root-finding__form-wrapper">
        <div class="root-finding__filters-container">
            <Switch TItem="AnalysisMode"
                    Data="@(Enum.GetValues<AnalysisMode>())"
                    @bind-Value="Mode"
                    TextField="@(item => item.ToString())"/>

            @switch (Mode)
            {
                case AnalysisMode.Single:
                    <Dropdown TItem="RootFindingMethod"
                              Data="@(Enum.GetValues<RootFindingMethod>())"
                              @bind-Value="Model.Method"
                              TextField="@(item => item.ToString())"/>
                    break;
                case AnalysisMode.Benchmark:
                    <Dropdown TItem="RootFindingMethod"
                              Data="@(Enum.GetValues<RootFindingMethod>())"
                              MultiSelect="true"
                              @bind-SelectedItems="ComparisonModel.SelectedMethods"
                              TextField="@(item => item.ToString())"/>
                    break;
                default:
                    throw new ArgumentOutOfRangeException();
            }
        </div>
        <div class="root-finding__form">
            <div class="input-section__wrapper">
                <MathInput @ref="_mathInputComponent" Label="@Localizer["Equation"]"
                           @bind-Value="Model.FunctionExpression"
                           OnInput="ShowChart"/>

                <div class="input-group">
                    <label class="input-group__label">
                        @(Model.Method == RootFindingMethod.Newton ? Localizer["InitialGuess"] : Localizer["StartPoint"])
                    </label>
                    <input type="number" @bind="Model.StartPoint" class="input-group__input" step="any" @ref="_startPointInput"/>
                </div>

                <div class="input-group">
                    <label class="input-group__label">@Localizer["EndPoint"]</label>
                    <input type="number" @bind="Model.EndPoint" class="input-group__group" step="any" @ref="_endPointInput"/>
                </div>

                <div class="input-group">
                    <label class="input-group__label">@Localizer["Tolerance"]</label>
                    <input type="number" @bind="Model.Tolerance" class="input-group__group" step="0.00001"/>
                </div>
            </div >
            <button class="button button--primary" @onclick="Calculate">@Localizer["Calculate"]</button>
        </div>        
        @if (Result?.SolutionSteps is { Count: > 0 })
        {
            <ul class="solution-steps__list">
                @foreach (var step in Result.SolutionSteps)
                {
                    <li class="solution-steps__item">
                        <span class="solution-steps__item-title">
                            @step.StepIndex 
                            @if (!string.IsNullOrWhiteSpace(step.Description))
                            { 
                                <span class="solution-steps__item-desc">&nbsp;&mdash;&nbsp;@Localizer[step.Description]</span>
                            }
                        </span>
                        <div class="solution-steps__item-text">
                            @if (step.IsThereTextContent)
                            {
                                if (!string.IsNullOrWhiteSpace(step.LatexFormula))
                                {
                                    <span class="solution-steps__item-formula">@($"{Localizer["LaTeXRecord"]}: {step.LatexFormula}").&nbsp;</span>
                                }
                                if (!string.IsNullOrWhiteSpace(step.Value))
                                {
                                    <span class="solution-steps__item-value">@($"{Localizer["GottenValue"]}: {step.Value}").</span>
                                }
                            }
                            else
                            {
                                @Localizer["ThereIsNoDescriptionToStep"]
                            }
                        </div>
                    </li>
                }
            </ul>
        }
        else
        {
            <div class="solution-steps__container--empty">
                <span class="remark">@Localizer["ClickCalculateToViewResult"]</span>
            </div>
        }
    </div>
    
    <div class="chart__container">
        <div class="chart" id="@ChartContainerId" style="display: @(_isChartBuilt ? "block" : "none");"></div>
        <span class="remark" style="display: @(_isChartBuilt ? "none" : "block");">@Localizer["ClickCalculateToViewResult"]</span>
    </div>
</div>

@page "/calculator/dichotomy"
@using Microsoft.AspNetCore.Components.Forms
@inherits BasePage

<h1>🔍 Метод Дихотомії</h1>

<div class="calculator-container">
    
    <div class="input-section">
        <EditForm Model="@RequestModel" OnValidSubmit="HandleCalculate">
            <DataAnnotationsValidator />
            
            <div class="form-group">
                <label>Function (Python syntax):</label>
                <InputText @bind-Value="RequestModel.FunctionExpression" class="form-control" placeholder="e.g. x**2 - 4" />
                <ValidationMessage For="@(() => RequestModel.FunctionExpression)" />
                <small class="hint">Use ** for power (e.g. x**3)</small>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label>Start Range (a):</label>
                    <InputNumber @bind-Value="RequestModel.StartRange" class="form-control" />
                    <ValidationMessage For="@(() => RequestModel.StartRange)" />
                </div>
                
                <div class="form-group half">
                    <label>End Range (b):</label>
                    <InputNumber @bind-Value="RequestModel.EndRange" class="form-control" />
                    <ValidationMessage For="@(() => RequestModel.EndRange)" />
                </div>
            </div>

            <div class="form-group">
                <label>Tolerance (Error):</label>
                <InputNumber @bind-Value="RequestModel.Error" class="form-control" Step="0.00001" />
                <ValidationMessage For="@(() => RequestModel.Error)" />
            </div>

            <button type="submit" class="btn-calculate">
                <span>🚀 Calculate Root</span>
            </button>
        </EditForm>
    </div>

    <div class="results-section">
        @if (Result != null)
        {
            <div class="result-card">
                <h3>Result Found!</h3>
                <p><strong>Root (x):</strong> @Result.Root</p>
                <p><strong>Iterations:</strong> @Result.Iterations</p>
            </div>
        }
        
        <div id="dichotomy-chart" class="chart-container"></div>
            
        @if(Result?.SolutionSteps != null && Result.SolutionSteps.Any())
        {
            <div class="steps-log">
                <h4>Solution Steps:</h4>
                @foreach(var step in Result.SolutionSteps)
                {
                    <div class="step-item">
                        <span class="step-idx">#@step.StepIndex</span> 
                        @step.Description
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .calculator-container {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }
    .input-section { flex: 1; min-width: 300px; padding: 20px; background: #f8f9fa; border-radius: 8px; }
    .results-section { flex: 2; min-width: 300px; }
    
    .form-group { margin-bottom: 15px; }
    .form-row { display: flex; gap: 10px; }
    .half { flex: 1; }
    
    .form-control { width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px; }
    .btn-calculate { width: 100%; padding: 10px; background: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; }
    .btn-calculate:disabled { background: #6c757d; }
    
    .alert-error { margin-top: 15px; padding: 10px; background: #f8d7da; color: #721c24; border-radius: 4px; border: 1px solid #f5c6cb; }
    .result-card { background: #d4edda; padding: 15px; border-radius: 8px; margin-bottom: 20px; color: #155724; }
    
    .chart-container { width: 100%; height: 400px; border: 1px solid #ddd; border-radius: 4px; }
    .hint { font-size: 0.8em; color: gray; }
</style>
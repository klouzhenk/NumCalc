@page "/optimization"
@using NumCalc.Shared.DTOs.Optimization
@using NumCalc.Shared.Enums.Optimization
@using NumCalc.UI.Shared.Components
@using NumCalc.UI.Shared.Components.Optimization
@using NumCalc.UI.Shared.Models.User.Enums
@using NumCalc.UI.Shared.Enums.Optimization
@using NumCalc.UI.Shared.Enums.Roots

@inherits BasePage<Optimization>

<div class="page-wrapper page__optimization">
    <div class="optimization__form-wrapper">
        <div class="page__filters-container">
            <Switch TItem="AnalysisMode"
                    Data="@(Enum.GetValues<AnalysisMode>())"
                    @bind-Value="_mode"
                    @bind-Value:after="ResetResult"
                    TextField="@(item => item.ToString())"
                    Label="@Localizer["AnalysisMode"]" />

            @if (_mode is AnalysisMode.Single)
            {
                <Dropdown TItem="OptimizationMethod"
                          Label="Method"
                          Data="@(Enum.GetValues<OptimizationMethod>())"
                          @bind-Value="_method"
                          @bind-Value:after="ResetResult"
                          TextField="@(item => item.ToString())" />
            }
            else
            {
                <Dropdown TItem="OptimizationComparisonMethod"
                          Label="Methods"
                          Data="@(Enum.GetValues<OptimizationComparisonMethod>())"
                          MultiSelect="true"
                          @bind-SelectedItems="_benchmarkMethods"
                          @bind-SelectedItems:after="ResetResult"
                          TextField="@(item => item.ToString())" />
            }

            <Switch TItem="bool"
                    Label="Goal"
                    Data="@(new[] { false, true })"
                    @bind-Value="_maximize"
                    @bind-Value:after="ResetResult"
                    TextField="@(b => b ? "Maximize" : "Minimize")" />
        </div>

        <div class="optimization__form">
            <OptimizationInput Method="_method" @ref="_input" />
            <div class="form-actions">
                <button class="button button--primary" @onclick="Calculate">Calculate</button>
                @if (_mode is AnalysisMode.Single && Result is not null)
                {
                    <button class="button button--secondary" @onclick="ExportPdfAsync">@Localizer["ExportPdf"]</button>
                }
            </div>
        </div>
    </div>

    <ResultPanel HasResult="Result is not null || ComparisonResult is not null">
        <Header>
            @if (_mode is AnalysisMode.Single && Result is not null)
            {
                <span>f(x*) = @Result!.MinimumValue.ToString("G6") (@(_maximize ? "max" : "min"))</span>
                @if (Result.ArgMinX.HasValue)
                {
                    <span>x* = @Result.ArgMinX.Value.ToString("G6")</span>
                }
                @if (Result.ArgMinPoint is { Count: > 0 })
                {
                    <span>x* = (@string.Join(", ", Result.ArgMinPoint.Select(v => v.ToString("G6"))))</span>
                }
            }
            else
            {
                <span>@Localizer["Benchmark"]</span>
            }
        </Header>
        <ChartContent>
            <div class="chart__container">
                <div class="chart" id="@ChartContainerId" style="display: @(IsChartVisible ? "block" : "none");"></div>
                <span class="remark" style="display: @(IsChartVisible ? "none" : "block");">@Localizer["ClickCalculateToViewResult"]</span>
            </div>
        </ChartContent>
        <ResultContent>
            @if (_mode is AnalysisMode.Single)
            {
                <SolutionStepsList Steps="@Result!.SolutionSteps" />
            }
            else if (ComparisonResult?.Results is { Count: > 0 })
            {
                <ComparisonResultList TItem="OptimizationBenchmarkResultDto"
                                      Items="ComparisonResult.Results"
                                      IsBest="@(item => item.Method == ComparisonResult.BestMethod)">
                    <ItemTemplate Context="item">
                        <span class="comparison-result__item-title">@Localizer[item.Method.ToString()]</span>
                        <div class="comparison-result__item-text">
                            <span class="comparison-result__item-subtitle">f(x*)</span>: @(item.MinimumValue?.ToString("G6") ?? "—")
                            @if (item.ArgMinX.HasValue)
                            {
                                <span> &nbsp;|&nbsp; <span class="comparison-result__item-subtitle">x*</span>: @item.ArgMinX.Value.ToString("G6")</span>
                            }
                            &nbsp;|&nbsp;
                            <span class="comparison-result__item-subtitle">@Localizer["ExecutionTime"]</span>: @item.ExecutionTimeMs.ToString("F3") @Localizer["ms"]
                        </div>
                    </ItemTemplate>
                </ComparisonResultList>
            }
        </ResultContent>
    </ResultPanel>
</div>

<SavedInputDataPanel Type="CalculationType.Optimization"
                     OnSave="SaveInputAsync"
                     OnLoad="LoadFromJsonAsync" />
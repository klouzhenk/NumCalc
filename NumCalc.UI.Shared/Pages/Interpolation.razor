@page "/interpolation"
@using NumCalc.UI.Shared.Components
@using NumCalc.UI.Shared.Components.Interpolation
@using NumCalc.UI.Shared.Models.User.Enums
@using NumCalc.Shared.DTOs.Interpolation
@using NumCalc.UI.Shared.Enums.Roots
@using InterpolationMethod = NumCalc.Shared.Enums.Interpolation.InterpolationMethod

@inherits BasePage<Interpolation>

<div class="page-wrapper page__interpolation">
    <div class="interpolation__form-wrapper">
        <div class="page__filters-container">
            <Switch TItem="AnalysisMode"
                    Data="@(Enum.GetValues<AnalysisMode>())"
                    @bind-Value="_analysisMode"
                    @bind-Value:after="ResetResult"
                    TextField="@(item => item.ToString())"
                    Label="@Localizer["AnalysisMode"]" />
            
            @if (_analysisMode is AnalysisMode.Single)
            {
                <Dropdown TItem="InterpolationMethod"
                          Label="Method"
                          Data="@(Enum.GetValues<InterpolationMethod>())"
                          @bind-Value="_method"
                          @bind-Value:after="ResetResult"
                          TextField="@(item => item.ToString())"/>
            }
            else
            {
                <Dropdown TItem="InterpolationMethod"
                          Label="Methods"
                          Data="@(Enum.GetValues<InterpolationMethod>())"
                          MultiSelect="true"
                          @bind-SelectedItems="_benchmarkMethods"
                          @bind-SelectedItems:after="ResetResult"
                          TextField="@(item => item.ToString())"/>
            }
        </div>

        <div class="interpolation__form">
            <InterpolationInput @ref="_input" />
            <div class="form-actions">
                <button class="button button--primary" @onclick="Calculate">@Localizer["Calculate"]</button>
                @if (Result is not null)
                {
                    <button class="button button--secondary" @onclick="ExportPdfAsync">@Localizer["ExportPdf"]</button>
                }
            </div>
            @if (IsAuthenticated)
            {
                <SavedInputActions ShowSaveForm="_showSaveForm"
                                   SaveName="@_saveInputName"
                                   SaveNameChanged="@(v => _saveInputName = v)"
                                   OnShowSave="@(() => _showSaveForm = true)"
                                   OnHideSave="@(() => _showSaveForm = false)"
                                   OnConfirmSave="ConfirmSaveAsync"
                                   OnLoad="OpenPickerAsync" />
                <SavedInputPickerModal @ref="_picker"
                                       Type="CalculationType.Interpolation"
                                       OnInputSelected="LoadFromJsonAsync" />
            }
        </div>
    </div>

    <ResultPanel HasResult="Result is not null || ComparisonResult is not null">
        <Header>
            @if (_analysisMode is AnalysisMode.Single && Result is not null)
            {
                <span>x* = @Result!.InterpolatedValue.ToString("G6")</span>
                <LatexDisplay Latex="@Result?.PolynomialLatex" Prefix="P(x) = " AdditionalCssClass="result-panel__formula"/>
            }
            else
            {
                <span>@Localizer["Benchmark"]</span>
            }
        </Header>
        <ChartContent>
            <div class="chart__container">
                <div class="chart" id="@ChartContainerId" style="display: @(IsChartVisible ? "block" : "none");"></div>
                <span class="remark" style="display: @(IsChartVisible ? "none" : "block");">@Localizer["ClickCalculateToViewResult"]</span>
            </div>
        </ChartContent>
        <ResultContent>
            @if (_analysisMode is AnalysisMode.Single)
            {
                <SolutionStepsList Steps="Result?.SolutionSteps" />
            }
            else if (ComparisonResult?.Results is { Count: > 0 })
            {
                <ComparisonResultList TItem="InterpolationBenchmarkResultDto"
                                      Items="ComparisonResult.Results"
                                      IsBest="@(item => item.Method == ComparisonResult.BestMethod)">
                    <ItemTemplate Context="item">
                        <span class="comparison-result__item-title">@Localizer[item.Method.ToString()]</span>
                        <div class="comparison-result__item-text">
                            <span class="comparison-result__item-subtitle">@Localizer["InterpolatedValue"]</span>: @(item.InterpolatedValue?.ToString("G6") ?? "—") &nbsp;|&nbsp;
                            <span class="comparison-result__item-subtitle">@Localizer["ExecutionTime"]</span>: @item.ExecutionTimeMs.ToString("F3") @Localizer["ms"]
                        </div>
                    </ItemTemplate>
                </ComparisonResultList>
            }
        </ResultContent>
    </ResultPanel>
</div>

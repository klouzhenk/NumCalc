@page "/interpolation"
@using NumCalc.Shared.Enums.Interpolation
@using NumCalc.UI.Shared.Components
@using NumCalc.UI.Shared.Components.Interpolation
@using NumCalc.UI.Shared.Enums.Interpolation

@inherits BasePage<Interpolation>

<div class="page-wrapper page__interpolation">
    <div class="interpolation__form-wrapper">

        <div class="interpolation__filters-container">
            <Switch TItem="InterpolationInputMode"
                    Data="@(Enum.GetValues<InterpolationInputMode>())"
                    @bind-Value="_mode"
                    TextField="@(item => item.ToString())" />

            <Dropdown TItem="InterpolationMethod"
                      Label="Method"
                      Data="@(Enum.GetValues<InterpolationMethod>())"
                      @bind-Value="_method"
                      TextField="@(item => item.ToString())" />
        </div>

        <div class="interpolation__form">
            <InterpolationInput Mode="_mode" @ref="_input" />
            <button class="button button--primary" @onclick="Calculate">@Localizer["Calculate"]</button>
        </div>

        @if (Result is not null)
        {
            <div class="interpolation-result">
                <div class="interpolation-result__answer">
                    <span>x* = @Result.InterpolatedValue</span>
                </div>

                @if (!string.IsNullOrEmpty(Result.PolynomialLatex))
                {
                    <div class="interpolation-result__polynomial">
                        <span class="solution-steps__item-formula">P(x) = @Result.PolynomialLatex</span>
                    </div>
                }

                <SolutionStepsList Steps="Result.SolutionSteps" />
            </div>
        }
        else
        {
            <div class="root-finding-result__container--empty">
                <span class="remark">@Localizer["ClickCalculateToViewResult"]</span>
            </div>
        }

    </div>

    <div class="chart__container">
        <div class="chart" id="@ChartContainerId" style="display: @(IsChartVisible ? "block" : "none");"></div>
        <span class="remark" style="display: @(IsChartVisible ? "none" : "block");">@Localizer["ClickCalculateToViewResult"]</span>
    </div>
</div>

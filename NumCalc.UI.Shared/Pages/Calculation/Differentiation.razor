@page "/differentiation"
@using NumCalc.Shared.DTOs.Differentiation
@using NumCalc.Shared.Enums.Differentiation
@using NumCalc.UI.Shared.Components
@using NumCalc.UI.Shared.Components.Differentiation
@using NumCalc.UI.Shared.Models.User.Enums
@using NumCalc.UI.Shared.Enums.Differentiation
@using NumCalc.UI.Shared.Enums.Roots
@using FiniteDiffVariant = NumCalc.Shared.Enums.Differentiation.FiniteDiffVariant

@inherits CalculationPage<Differentiation>

<div class="page-wrapper page__differentiation">
    <div class="differentiation__form-wrapper">
        <div class="page__filters-container">
            <Switch TItem="AnalysisMode"
                    Data="@(Enum.GetValues<AnalysisMode>())"
                    @bind-Value="_mode"
                    @bind-Value:after="ResetResult"
                    TextField="@(item => item.ToString())"
                    Label="@Localizer["AnalysisMode"]" />

            @if (_mode is AnalysisMode.Single)
            {
                <Dropdown TItem="DifferentiationMethod"
                          Label="Method"
                          Data="@(Enum.GetValues<DifferentiationMethod>())"
                          @bind-Value="_method"
                          @bind-Value:after="ResetResult"
                          TextField="@(item => item.ToString())" />

                @if (_method is DifferentiationMethod.FiniteDifferences)
                {
                    <Dropdown TItem="FiniteDiffVariant"
                              Label="Variant"
                              Data="@(Enum.GetValues<FiniteDiffVariant>())"
                              @bind-Value="_variant"
                              @bind-Value:after="ResetResult"
                              TextField="@(item => item.ToString())" />
                }
                else
                {
                    <Switch TItem="DifferentiationInputMode"
                            Label="@Localizer["Mode"]"
                            Data="@(Enum.GetValues<DifferentiationInputMode>())"
                            @bind-Value="_inputMode"
                            @bind-Value:after="ResetResult"
                            TextField="@(item => item.ToString())" />
                }
            }
            else
            {
                <Dropdown TItem="DifferentiationComparisonMethod"
                          Label="Methods"
                          Data="@(Enum.GetValues<DifferentiationComparisonMethod>())"
                          MultiSelect="true"
                          @bind-SelectedItems="_benchmarkMethods"
                          @bind-SelectedItems:after="ResetResult"
                          TextField="@(item => item.ToString())" />
            }
        </div>

        <div class="differentiation__form">
            <DifferentiationInput Method="_method" Mode="_inputMode" @ref="_input" />
            <div class="form-actions">
                <button class="button button--primary" @onclick="Calculate">Calculate</button>
                @if (_mode is AnalysisMode.Single && Result is not null)
                {
                    <button class="button button--secondary" @onclick="ExportPdfAsync">@Localizer["ExportPdf"]</button>
                }
            </div>
        </div>
    </div>

    <ResultPanel HasResult="Result is not null || ComparisonResult is not null">
        <Header>
            @if (_mode is AnalysisMode.Single && Result is not null)
            {
                <span>@(_lastDerivativeOrder == 2 ? "f''(x*)" : "f'(x*)") = @Result!.DerivativeValue.ToString("G6")</span>
                <LatexDisplay Latex="@Result!.PolynomialLatex" AdditionalCssClass="result-panel__formula" />
            }
            else
            {
                <span>@Localizer["Benchmark"]</span>
            }
        </Header>
        <ChartContent>
            <div class="chart__container">
                <div class="chart" id="@ChartContainerId" style="display: @(IsChartVisible ? "block" : "none");"></div>
                <span class="remark" style="display: @(IsChartVisible ? "none" : "block");">@Localizer["ClickCalculateToViewResult"]</span>
            </div>
        </ChartContent>
        <ResultContent>
            @if (_mode is AnalysisMode.Single)
            {
                <SolutionStepsList Steps="Result?.SolutionSteps" />
            }
            else if (ComparisonResult?.Results is { Count: > 0 })
            {
                <ComparisonResultList TItem="DifferentiationBenchmarkResultDto"
                                      Items="ComparisonResult.Results"
                                      IsBest="@(item => item.Method == ComparisonResult.BestMethod)">
                    <ItemTemplate Context="item">
                        <span class="comparison-result__item-title">@Localizer[item.Method.ToString()]</span>
                        <div class="comparison-result__item-text">
                            <span class="comparison-result__item-subtitle">@(_lastDerivativeOrder == 2 ? "f''" : "f'")(x*)</span>: @(item.DerivativeValue?.ToString("G6") ?? "—") &nbsp;|&nbsp;
                            <span class="comparison-result__item-subtitle">@Localizer["ExecutionTime"]</span>: @item.ExecutionTimeMs.ToString("F3") @Localizer["ms"]
                        </div>
                    </ItemTemplate>
                </ComparisonResultList>
            }
        </ResultContent>
    </ResultPanel>
</div>

<SavedInputDataPanel Type="CalculationType.Differentiation"
                     OnSave="SaveInputAsync"
                     OnLoad="LoadFromJsonAsync" />